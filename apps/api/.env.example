PORT=3100
DATABASE_URL=postgres://tatamiq:tatamiq@localhost:5432/tatamiq
WEB_APP_URL=http://localhost:5173
# Additional browser origins are comma-separated, e.g. local web against staging API.
CORS_ORIGIN=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3100
BETTER_AUTH_SECRET=dev-only-tatamiq-better-auth-secret-change-me-minimum-32-chars
COOKIE_DOMAIN=
COOKIE_SECURE=false
# Set to none with COOKIE_SECURE=true when browser and API are cross-site.
COOKIE_SAME_SITE=lax
LOG_LEVEL=info

# Email (Resend). Empty RESEND_API_KEY enables sanitized local/test fallback only; configure it in production.
RESEND_API_KEY=
EMAIL_FROM="Tatamiq <noreply@example.com>"

# Cloudflare R2 (receipt uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
