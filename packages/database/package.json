{
  "name": "@tatamiq/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:seed:e2e": "tsx src/seed-e2e.ts"
  },
  "dependencies": {
    "better-auth": "^1.6.11",
    "drizzle-orm": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
